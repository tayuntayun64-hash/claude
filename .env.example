# ─────────────────────────────────────────────
# Konfigurasi ENV — salin file ini ke .env lalu isi nilainya
# Jangan pernah commit file .env ke repository!
# ─────────────────────────────────────────────

# Token bot Motion Control (bot_telegram_motion_pro.py)
MOTION_BOT_TOKEN=ISI_TOKEN_MOTION_BOT_DISINI

# Token bot NS Store Order (ns_store_bot.py)
NS_STORE_BOT_TOKEN=ISI_TOKEN_NS_STORE_BOT_DISINI

# Telegram ID channel pribadi untuk history
# Cara cari: forward pesan dari channel ke @userinfobot, ambil "Chat ID"
# (untuk channel biasanya format -100xxxxxxxxxx)
#
# Kalau mau pakai 1 channel untuk KEDUA bot:
HISTORY_CHANNEL_ID=-100XXXXXXXXXX
#
# Atau kalau mau channel terpisah per bot:
# MOTION_HISTORY_CHANNEL_ID=-100XXXXXXXXXX
# NS_STORE_HISTORY_CHANNEL_ID=-100XXXXXXXXXX

# Admin Telegram ID (default: 1038443084)
ADMIN_ID=1038443084
